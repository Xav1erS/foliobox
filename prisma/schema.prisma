// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// NextAuth.js required models
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// App models
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // App relations
  profile           DesignerProfile?
  resumes           Resume[]
  projects          Project[]
  portfolios        Portfolio[]
  portfolioScores   PortfolioScore[]
  portfolioOutlines PortfolioOutline[]
  portfolioDrafts   PortfolioDraft[]
  publishedPortfolios PublishedPortfolio[]
  orders            Order[]
  userPlans         UserPlan[]
  llmUsageEvents    LLMUsageEvent[]
  externalParseUsageEvents ExternalParseUsageEvent[]
  generationTasks   GenerationTask[]
  precheckLogs      PrecheckLog[]
  budgetUsageEvents BudgetUsageEvent[]
}

model DesignerProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  currentTitle      String?
  yearsOfExperience String?
  industry          String?
  specialties       String[]
  targetRole        String?
  strengths         String[]
  tonePreference    String?
  source            ProfileSource @default(MANUAL)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ProfileSource {
  MANUAL
  RESUME_PARSE
}

model Resume {
  id          String      @id @default(cuid())
  userId      String
  fileUrl     String
  fileType    ResumeFileType
  parseStatus ParseStatus @default(PENDING)
  rawText     String?     @db.Text
  parsedJson  Json?
  createdAt   DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ResumeFileType {
  PDF
  DOCX
}

enum ParseStatus {
  PENDING
  DONE
  FAILED
}

model Project {
  id           String        @id @default(cuid())
  userId       String
  name         String
  sourceType   ProjectSource
  sourceUrl    String?
  importStatus ImportStatus  @default(DRAFT)
  // V3 stage field (replaces importStatus as primary status signal)
  stage        ProjectStage  @default(DRAFT)
  // V3 AI output per stage
  boundaryJson     Json?
  completenessJson Json?
  packageJson      Json?
  layoutJson       Json?
  packageMode      PackageMode?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets   ProjectAsset[]
  facts    ProjectFact?
  outlines PortfolioOutline[] @relation("OutlineProjects")
  drafts   PortfolioDraft[]
  llmUsageEvents LLMUsageEvent[]
}

enum ProjectStage {
  DRAFT
  BOUNDARY
  COMPLETENESS
  PACKAGE
  LAYOUT
  READY
}

enum PackageMode {
  DEEP
  LIGHT
  SUPPORTIVE
}

enum ProjectSource {
  FIGMA
  IMAGES
  MANUAL
}

enum ImportStatus {
  DRAFT
  IMPORTING
  IMPORTED
  FAILED
}

model ProjectAsset {
  id        String    @id @default(cuid())
  projectId String
  assetType AssetType
  title     String?
  imageUrl  String
  sortOrder Int       @default(0)
  selected  Boolean   @default(false)
  isCover   Boolean   @default(false)
  metaJson  Json?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sortOrder])
}

enum AssetType {
  PAGE
  FRAME
  IMAGE
}

model ProjectFact {
  id                 String            @id @default(cuid())
  projectId          String            @unique
  projectType        String?
  industry           String?
  timeline           String?
  stage              String?
  hasLaunched        Boolean?
  background         String?           @db.Text
  targetUsers        String?           @db.Text
  businessGoal       String?           @db.Text
  constraints        String?           @db.Text
  roleTitle          String?
  involvementLevel   InvolvementLevel?
  responsibilities   String[]
  collaborators      String[]
  keyContribution    String?           @db.Text
  biggestChallenge   String?           @db.Text
  keyHighlights      String[]
  designRationale    String?           @db.Text
  tradeoffs          String?           @db.Text
  resultSummary      String?           @db.Text
  measurableImpact   String?           @db.Text
  substituteEvidence String?           @db.Text
  targetJob          String?
  targetCompanyType  String?
  emphasis           String[]
  tonePreference     String?
  updatedAt          DateTime          @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum InvolvementLevel {
  LEAD
  CORE
  SUPPORT
}

model PortfolioScore {
  id                 String         @id @default(cuid())
  userId             String?
  anonymousSessionId String?
  requestIpHash      String?
  inputType          ScoreInputType
  inputUrl           String?
  totalScore         Int
  level              ScoreLevel
  dimensionScores    Json
  coverageJson       Json?
  processingJson     Json?
  summaryPoints      String[]
  recommendedActions String[]
  createdAt          DateTime       @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  llmUsageEvents LLMUsageEvent[]
  externalParseUsageEvents ExternalParseUsageEvent[]

  @@index([anonymousSessionId, createdAt])
  @@index([requestIpHash, createdAt])
}

enum ScoreInputType {
  LINK
  PDF
  IMAGES
}

enum ScoreLevel {
  READY
  NEEDS_IMPROVEMENT
  DRAFT
  NOT_READY
}

model PortfolioOutline {
  id                   String        @id @default(cuid())
  userId               String
  status               OutlineStatus @default(DRAFT)
  overallTheme         VariantType   @default(BALANCED)
  totalEstimatedPages  Int           @default(0)
  estimatedTokenCost   Int?
  sectionsJson         Json
  selectedThumbnailMap Json          @default("{}")
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]        @relation("OutlineProjects")
  drafts   PortfolioDraft[]
  llmUsageEvents LLMUsageEvent[]
}

enum OutlineStatus {
  DRAFT
  CONFIRMED
  RENDERING
  DONE
  FAILED
}

enum VariantType {
  PROFESSIONAL
  BALANCED
  EXPRESSIVE
}

model PortfolioDraft {
  id          String       @id @default(cuid())
  userId      String
  projectId   String
  outlineId   String?
  variantType VariantType
  status      DraftStatus  @default(PENDING)
  title       String?
  contentJson Json
  previewHtml String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  outline   PortfolioOutline? @relation(fields: [outlineId], references: [id], onDelete: SetNull)
  published PublishedPortfolio?
  llmUsageEvents LLMUsageEvent[]
}

model LLMUsageEvent {
  id                String   @id @default(cuid())
  provider          String
  method            String
  task              String
  model             String
  success           Boolean  @default(true)
  elapsedMs         Int
  promptTokens      Int?
  completionTokens  Int?
  totalTokens       Int?
  inputType         String?
  fileSizeBytes     Int?
  pageCount         Int?
  itemCount         Int?
  errorMessage      String?  @db.Text
  metadataJson      Json?
  userId            String?
  projectId         String?
  outlineId         String?
  draftId           String?
  portfolioScoreId  String?
  createdAt         DateTime @default(now())

  user           User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  project        Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  outline        PortfolioOutline? @relation(fields: [outlineId], references: [id], onDelete: SetNull)
  draft          PortfolioDraft?  @relation(fields: [draftId], references: [id], onDelete: SetNull)
  portfolioScore PortfolioScore?  @relation(fields: [portfolioScoreId], references: [id], onDelete: SetNull)

  @@index([task, createdAt])
  @@index([userId, createdAt])
  @@index([projectId, createdAt])
  @@index([outlineId, createdAt])
  @@index([draftId, createdAt])
  @@index([portfolioScoreId, createdAt])
}

model ExternalParseUsageEvent {
  id               String   @id @default(cuid())
  provider         String
  success          Boolean  @default(true)
  elapsedMs        Int
  pageCount        Int?
  estimatedCostUsd Float?
  fileSizeBytes    Int?
  errorMessage     String?  @db.Text
  metadataJson     Json?
  userId           String?
  portfolioScoreId String?
  createdAt        DateTime @default(now())

  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  portfolioScore PortfolioScore? @relation(fields: [portfolioScoreId], references: [id], onDelete: SetNull)

  @@index([provider, createdAt])
  @@index([userId, createdAt])
  @@index([portfolioScoreId, createdAt])
}

enum DraftStatus {
  PENDING
  DONE
  FAILED
}

model PublishedPortfolio {
  id            String   @id @default(cuid())
  draftId       String?  @unique   // V2 source (optional for V3)
  portfolioId   String?            // V3 source
  userId        String
  slug          String   @unique
  publishedHtml String   @db.Text
  pdfUrl        String?
  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  draft     PortfolioDraft? @relation(fields: [draftId], references: [id], onDelete: Cascade)
  portfolio Portfolio?      @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// V3: Portfolio (first-class object)
// ─────────────────────────────────────────────

model Portfolio {
  id          String          @id @default(cuid())
  userId      String
  name        String
  status      PortfolioStatus @default(DRAFT)
  projectIds  String[]
  outlineJson Json?
  contentJson Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  published PublishedPortfolio[]

  @@index([userId, updatedAt])
}

enum PortfolioStatus {
  DRAFT
  SELECTION
  OUTLINE
  EDITOR
  PUBLISHED
}

// ─────────────────────────────────────────────
// V3: Generation system
// ─────────────────────────────────────────────

model GenerationTask {
  id                    String   @id @default(cuid())
  userId                String
  objectType            String   // "project" | "portfolio"
  objectId              String   // stores projectId or portfolioId (no FK, polymorphic)
  actionType            String   // "boundary_identification" | "project_layout_generation" | ...
  usageClass            String   // "low_cost" | "high_cost"
  provider              String?
  model                 String?
  requestHash           String?
  status                String   @default("pending") // "pending" | "running" | "done" | "failed" | "reused"
  reusedFromTaskId      String?
  styleReferenceSetHash String?
  wasSuccessful         Boolean  @default(false)
  countedToBudget       Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  drafts GeneratedDraft[]

  @@index([userId, createdAt])
  @@index([objectType, objectId])
  @@index([requestHash])
}

model GeneratedDraft {
  id            String   @id @default(cuid())
  userId        String
  objectType    String   // "project" | "portfolio"
  objectId      String
  sourceTaskId  String
  draftType     String   // "layout" | "packaging" | "rewrite" | "validation"
  versionNumber Int      @default(1)
  contentJson   Json
  isReusable    Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sourceTask GenerationTask @relation(fields: [sourceTaskId], references: [id], onDelete: Cascade)

  @@index([objectType, objectId, draftType])
  @@index([sourceTaskId])
}

model PrecheckLog {
  id              String   @id @default(cuid())
  userId          String
  objectType      String   // "project" | "portfolio"
  objectId        String   // stores projectId or portfolioId (no FK, polymorphic)
  actionType      String
  budgetStatus    String   // "healthy" | "near_limit" | "needs_topup"
  suggestedMode   String   // "continue" | "reuse" | "downgrade" | "block"
  reusableDraftId String?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([objectType, objectId])
}

model BudgetUsageEvent {
  id              String   @id @default(cuid())
  userId          String
  objectType      String   // "project" | "portfolio"
  objectId        String
  actionType      String
  usageClass      String   // "low_cost" | "high_cost"
  wasReused       Boolean  @default(false)
  wasSuccessful   Boolean  @default(true)
  countedToBudget Boolean  @default(true)
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([objectType, objectId])
}

// ─────────────────────────────────────────────
// Billing models
// ─────────────────────────────────────────────

enum PlanType {
  FREE
  PRO
  SPRINT
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum PlanStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum BillingEventType {
  CREATED
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  planType        PlanType
  amount          Int
  currency        String      @default("CNY")
  status          OrderStatus @default(PENDING)
  provider        String?
  providerOrderId String?
  // Return context (7.15C): stored server-side so result page doesn't trust URL params
  sourceScene     String?     // e.g. "pdf_export" | "full_rewrite" | "publish_link"
  projectId       String?
  draftId         String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  events   BillingEvent[]
  userPlan UserPlan?
}

model UserPlan {
  id            String     @id @default(cuid())
  userId        String
  planType      PlanType   @default(FREE)
  status        PlanStatus @default(ACTIVE)
  startedAt     DateTime?
  expiresAt     DateTime?
  sourceOrderId String?    @unique
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [sourceOrderId], references: [id], onDelete: SetNull)
}

model BillingEvent {
  id          String           @id @default(cuid())
  orderId     String
  eventType   BillingEventType
  payloadJson Json?
  createdAt   DateTime         @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
