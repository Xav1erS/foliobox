# Database (Supabase PostgreSQL - Transaction Pooler 模式)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# NextAuth
APP_BASE_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="your-secret-here-run-openssl-rand-base64-32"
CANONICAL_HOST_ALIASES=""
ALLOW_STUB_PAYMENTS="true"

# Email (开发用 Nodemailer，生产配 Resend / 阿里云邮件)
EMAIL_SERVER_HOST="smtp.ethereal.email"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@foliobox.design"

# OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_MODEL_PRIMARY="gpt-5.4-mini"
OPENAI_MODEL_LITE="gpt-5.4-nano"
OPENAI_MODEL_VISION="gpt-5.4-mini"

# Mistral OCR
PDF_PARSE_PRIMARY_PROVIDER="mistral_ocr"
PDF_PARSE_PROVIDER_CHAIN="mistral_ocr,pdf_parse_fallback"
MISTRAL_API_KEY=""
MISTRAL_BASE_URL="https://api.mistral.ai"
MISTRAL_OCR_MODEL="mistral-ocr-latest"
MISTRAL_OCR_TIMEOUT_MS="60000"
MISTRAL_OCR_MAX_RETRIES="2"
MISTRAL_OCR_RETRY_DELAY_MS="1500"
MISTRAL_OCR_ESTIMATED_COST_PER_PAGE_USD=""
MISTRAL_PROVIDER_DISPLAY_NAME="Mistral OCR"
MISTRAL_PROVIDER_REGION="global"
MISTRAL_PROVIDER_NETWORK_PROFILE="mainland_uncertain"
MISTRAL_PROVIDER_STABILITY_TIER="candidate"

# Azure Document Intelligence
AZURE_DOCINTEL_ENDPOINT=""
AZURE_DOCINTEL_API_KEY=""
AZURE_DOCINTEL_MODEL_ID="prebuilt-layout"
AZURE_DOCINTEL_API_VERSION="2024-11-30"
AZURE_DOCINTEL_ESTIMATED_COST_PER_PAGE_USD=""
AZURE_DOCINTEL_PROVIDER_DISPLAY_NAME="Azure Document Intelligence"
AZURE_DOCINTEL_PROVIDER_REGION="global"
AZURE_DOCINTEL_PROVIDER_NETWORK_PROFILE="mainland_uncertain"
AZURE_DOCINTEL_PROVIDER_STABILITY_TIER="candidate"

# Claude PDF
ANTHROPIC_API_KEY=""
ANTHROPIC_BASE_URL="https://api.anthropic.com"
ANTHROPIC_PDF_MODEL="claude-3-5-haiku-latest"
ANTHROPIC_PDF_TIMEOUT_MS="90000"
ANTHROPIC_INPUT_COST_PER_MTOKENS="0.8"
ANTHROPIC_OUTPUT_COST_PER_MTOKENS="4"
ANTHROPIC_PROVIDER_DISPLAY_NAME="Claude PDF"
ANTHROPIC_PROVIDER_REGION="global"
ANTHROPIC_PROVIDER_NETWORK_PROFILE="mainland_uncertain"
ANTHROPIC_PROVIDER_STABILITY_TIER="candidate"

# Vercel Blob
BLOB_READ_WRITE_TOKEN="vercel_blob_..."
SCORE_UPLOAD_TOKEN_LIMIT="30"
SCORE_UPLOAD_WINDOW_MS="3600000"

# Feature Flags
LLM_PROVIDER="openai"
